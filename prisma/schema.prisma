generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Car {
  id              Int      @id @default(autoincrement())
  make            String
  model           String
  variant         String
  segment         String
  price           Float
  fuelType        String
  transmission    String
  mileage         Float
  engineCC        Int?
  seatingCapacity Int
  bootSpace       Int
  safetyRating    Float
  powerBHP        Int
  groundClearance Int
  pros            String
  cons            String
  reviews         Review[]
}

model Review {
  id        Int      @id @default(autoincrement())
  carId     Int
  car       Car      @relation(fields: [carId], references: [id])
  author    String
  rating    Float
  comment   String
  createdAt DateTime @default(now())
}
